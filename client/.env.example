# ─── Client (.env in /client) ───────────────────────────────────
# URL of your signaling server (no trailing slash)
VITE_SOCKET_URL=http://localhost:3001

# ─── Server (.env in /server) ───────────────────────────────────
PORT=3001

# Hosted LibreTranslate service (configured on the server, not the client).
# Community mirrors have no uptime guarantee; replace this URL if needed.
LIBRETRANSLATE_URL=https://translate.terraprint.co/translate
# Optional; only required by LibreTranslate providers that require a key.
LIBRETRANSLATE_API_KEY=

# ─── TURN Server (add to ICE_SERVERS in usePeerConnections.js) ──
# Required for users behind symmetric NAT (corporate networks, etc.)
# 
# Option 1 — Cloudflare TURN (free tier available)
#   https://developers.cloudflare.com/calls/turn/
#
# Option 2 — Twilio (pay-as-you-go)
#   TURN_URL=turn:global.turn.twilio.com:3478
#   TURN_USER=<from Twilio console>
#   TURN_CRED=<from Twilio console>
#
# Option 3 — Self-host with coturn
#   sudo apt install coturn
#   See DEPLOYMENT.md for full coturn config
